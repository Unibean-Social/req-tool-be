DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/reqflow

JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# GitHub OAuth App — user login (scope: read:user, user:email)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback
# generate: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_STATE_SECRET=

# GitHub App — repo connection (installation flow)
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_CLIENT_ID=your_github_app_client_id
# generate: python -c "f=open(r'YOURFILE.private-key.pem').read().strip(); print(f.replace('\r\n',r'\n').replace('\n',r'\n'))"
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=your-app-slug
GITHUB_APP_REDIRECT_URI=http://localhost:8000/api/v1/github/app/setup

# generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# generate: python -c "import secrets; print(secrets.token_hex(32))"
PASSWORD_PEPPER=

APP_ENV=development
APP_DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
AUTO_MIGRATE=true
