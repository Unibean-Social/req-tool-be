# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/reqflow

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# GitHub OAuth (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Must match exactly what is registered in GitHub OAuth App settings
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Token encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
